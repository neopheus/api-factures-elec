{
  "name": "factelec",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "audit:ci": "node scripts/audit.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.0",
      "postcss": "8.5.19"
    },
    "updateConfig": {
      "ignoreDependencies": [
        "typescript"
      ]
    },
    "onlyBuiltDependencies": [
      "msgpackr-extract"
    ]
  }
}

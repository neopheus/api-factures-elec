{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // "node" explicite : src/facturx/generate.ts importe node:crypto
    // (createHash, calcul pur — cf. README, purity src/). Contrairement à
    // tsconfig.json (typecheck), ce programme n'inclut pas tests/ et n'a donc
    // pas d'inclusion transitive des types Node via vitest/vite.
    "types": ["node"]
  },
  "include": ["src/**/*"]
}

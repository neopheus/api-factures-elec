{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factelec.dev/schemas/connectors-sdk/order-mapping.schema.json",
  "title": "Payload de dépôt POST /invoices (contrat connecteur)",
  "description": "Équivalent JSON Schema 2020-12 de `invoiceInputSchema` (packages/invoice-core/src/model/schema.ts, zod) — chaque contrainte structurelle du zod réel est transposée ici. Deux écarts documentés et assumés (voir les notes sur les propriétés concernées ci-dessous) : (1) `issueDate`/`dueDate` ne vérifient que la FORME AAAA-MM-JJ, pas la validité calendaire réelle (zod applique en plus `isExistingCalendarDate`, ex. rejette 2026-02-30 — non reproductible en JSON Schema pur sans mot-clé de format personnalisé) ; (2) `exemptionReasonCode` ne vérifie que le PRÉFIXE de nommage VATEX-EU-*/VATEX-FR-*, pas l'appartenance à la liste blanche BR-CL-22 complète (88 codes, invoice-core `vatex.ts`) — dupliquer cette liste ici créerait un risque de dérive silencieuse pour un champ hors du périmètre structurel de ce contrat (aucune fixture de ce paquet n'utilise de catégorie exonérée, précisément pour ne pas dépendre de cette liste).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "number": {
      "type": "string",
      "minLength": 1,
      "description": "BT-1 — numéro de facture, unique par tenant."
    },
    "issueDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "BT-2 — AAAA-MM-JJ. Forme uniquement, voir note du schéma sur la validité calendaire."
    },
    "dueDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "BT-9 — AAAA-MM-JJ, optionnel. Forme uniquement, voir note du schéma."
    },
    "typeCode": {
      "type": "string",
      "enum": ["380", "381"],
      "description": "BT-3 — facture (380) ou avoir (381)."
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "BT-5 — ISO 4217, ex. EUR."
    },
    "seller": { "$ref": "#/$defs/party" },
    "buyer": { "$ref": "#/$defs/party" },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/invoiceLine" },
      "description": "BG-25 — au moins une ligne."
    },
    "businessProcessType": {
      "type": "string",
      "enum": [
        "B1",
        "S1",
        "M1",
        "B2",
        "S2",
        "M2",
        "B4",
        "S4",
        "M4",
        "S5",
        "S6",
        "B7",
        "S7"
      ],
      "description": "BT-23 — cadre de facturation DGFiP (règle G1.02), optionnel."
    }
  },
  "required": [
    "number",
    "issueDate",
    "typeCode",
    "currency",
    "seller",
    "buyer",
    "lines"
  ],
  "$defs": {
    "postalAddress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "streetName": { "type": "string", "minLength": 1 },
        "city": { "type": "string", "minLength": 1 },
        "postalCode": { "type": "string", "minLength": 1 },
        "countryCode": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2, ex. FR."
        }
      },
      "required": ["countryCode"]
    },
    "party": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "siren": {
          "type": "string",
          "pattern": "^\\d{9}$|^\\d{14}$",
          "description": "SIREN (9 chiffres) ou SIRET (14), optionnel."
        },
        "vatId": {
          "type": "string",
          "pattern": "^[A-Z]{2}[0-9A-Z]{2,12}$",
          "description": "Numéro de TVA intracommunautaire, optionnel."
        },
        "address": { "$ref": "#/$defs/postalAddress" }
      },
      "required": ["name", "address"]
    },
    "invoiceLine": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "quantity": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d{1,4})?$",
          "description": "Décimal non négatif, jusqu'à 4 décimales."
        },
        "unitCode": {
          "type": "string",
          "minLength": 2,
          "maxLength": 3,
          "description": "UN/ECE recommandation 20, ex. C62."
        },
        "unitPrice": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d{1,4})?$",
          "description": "Décimal non négatif, jusqu'à 4 décimales."
        },
        "vatCategory": {
          "type": "string",
          "enum": ["S", "Z", "E", "AE", "K", "G", "O", "L", "M"]
        },
        "vatRate": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d{1,4})?$",
          "description": "Pourcentage, décimal non négatif jusqu'à 4 décimales."
        },
        "exemptionReasonCode": {
          "type": "string",
          "pattern": "^VATEX-(EU|FR)-",
          "description": "Approximation de forme (préfixe) — voir note du schéma, liste blanche BR-CL-22 non reproduite intégralement."
        },
        "exemptionReason": { "type": "string", "minLength": 1 },
        "nature": {
          "type": "string",
          "enum": ["goods", "services"]
        }
      },
      "required": [
        "id",
        "name",
        "quantity",
        "unitCode",
        "unitPrice",
        "vatCategory",
        "vatRate"
      ]
    }
  }
}

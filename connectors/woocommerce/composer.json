{
    "name": "factelec/woocommerce-connector",
    "description": "Connecteur WooCommerce pour Factelec — dépôt de facture électronique à la transition de statut de commande (plugin factelec/, aucune dépendance runtime).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.59"
    },
    "autoload": {
        "psr-4": {
            "FactelecWoo\\": "factelec/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FactelecWoo\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/stubs/"
        ],
        "files": [
            "tests/stubs/wp-functions.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false,
        "platform": {
            "php": "8.2.0"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    }
}

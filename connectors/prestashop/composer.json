{
    "name": "factelec/prestashop-connector",
    "description": "Connecteur PrestaShop 8.x pour Factelec — dépôt de facture électronique à la validation de commande (module factelec/, aucune dépendance runtime).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.59"
    },
    "autoload": {
        "psr-4": {
            "Factelec\\": "factelec/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Factelec\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/stubs/"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    }
}

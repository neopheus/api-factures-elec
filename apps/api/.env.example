NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Rôle applicatif (runtime) — soumis à la RLS, sans BYPASSRLS
DATABASE_URL=postgres://factelec_app:app_pw@localhost:5432/factelec
# Rôle propriétaire — migrations & provisioning UNIQUEMENT (jamais le runtime)
DATABASE_OWNER_URL=postgres://factelec_owner:owner_pw@localhost:5432/factelec
# Origine du dashboard marchand (cookies de session envoyés avec credentials).
# Dev : dashboard sur 3001 (cf. Task 8). Prod : https://dashboard.factelec.fr
CORS_ALLOWED_ORIGINS=http://localhost:3001
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120
# Nombre de proxys de confiance devant l'API ; 0 = connexion directe (défaut,
# aucun proxy). À positionner derrière un load balancer / reverse-proxy pour
# que le rate limiting par IP lise la vraie IP client via X-Forwarded-For.
TRUST_PROXY=0
# Durée de vie ABSOLUE de la session (heures) ; pas de renouvellement glissant.
SESSION_TTL_HOURS=12
# Domaine du cookie de session — prod uniquement (partage dashboard/API sur
# sous-domaines) ; absent en dev (localhost).
# SESSION_COOKIE_DOMAIN=.factelec.fr

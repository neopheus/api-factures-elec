{
  "name": "@factelec/api",
  "version": "0.14.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "swc src --out-dir dist --strip-leading-paths && rm -rf dist/db/migrations && cp -r src/db/migrations dist/db/migrations",
    "dev": "node --import tsx --watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "start:worker": "node dist/worker-main.js",
    "worker:dev": "node --import tsx --watch src/worker-main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx scripts/migrate.ts",
    "provision:tenant": "node --import tsx scripts/provision-tenant.ts",
    "provision:admin": "node --import tsx scripts/provision-admin.ts",
    "billing:bootstrap": "node --import tsx scripts/billing-bootstrap.ts"
  },
  "dependencies": {
    "@factelec/invoice-core": "workspace:*",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/throttler": "6.5.0",
    "@node-rs/argon2": "2.0.2",
    "big.js": "7.0.1",
    "bullmq": "5.80.9",
    "cookie-parser": "1.4.7",
    "drizzle-orm": "0.45.2",
    "helmet": "8.3.0",
    "nestjs-pino": "4.6.1",
    "otplib": "13.4.1",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "stripe": "22.3.2",
    "xmlbuilder2": "4.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.46",
    "@testcontainers/postgresql": "12.0.4",
    "@testcontainers/redis": "12.0.4",
    "@types/big.js": "7.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.1",
    "@vitest/coverage-v8": "4.1.10",
    "drizzle-kit": "0.31.10",
    "supertest": "7.2.2",
    "testcontainers": "12.0.4",
    "tsx": "4.23.1",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.10"
  }
}
